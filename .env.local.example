# ── Azure / Microsoft Graph (for email) ──────────────────────────────────────
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# ── Mailchimp (for lead capture) ──────────────────────────────────────────────
MAILCHIMP_API_KEY=your-api-key-us21
MAILCHIMP_LIST_ID=your-list-id

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs for each product
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_ROADMAP=price_...
STRIPE_PRICE_INDIE=price_...
STRIPE_PRICE_SURROGATE=price_...
STRIPE_PRICE_PROFILE=price_...

# Stripe Checkout Links (for buy buttons on /programs)
STRIPE_STARTER_LINK=https://buy.stripe.com/...
STRIPE_ROADMAP_LINK=https://buy.stripe.com/...
STRIPE_INDIE_LINK=https://buy.stripe.com/...
STRIPE_SURROGATE_LINK=https://buy.stripe.com/...
STRIPE_PROFILE_LINK=https://buy.stripe.com/...

# ── PDF Delivery URLs ──────────────────────────────────────────────────────────
PDF_STARTER_URL=/pdfs/is-surrogacy-right-for-me.pdf
PDF_ROADMAP_URL=/pdfs/roadmap.pdf
PDF_INDIE_URL=/pdfs/indie-checklist.pdf
PDF_SURROGATE_URL=/pdfs/surrogate-readiness.pdf
PDF_PROFILE_URL=/pdfs/ip-profile-template.pdf
PDF_IP_COST_GUIDE_URL=/pdfs/canadian-surrogacy-cost-guide.pdf

# ── Google Tags (hardcoded in app/layout.tsx — no env var needed) ────────────
# G-G9L2PTW3ES = GA4 measurement ID
# GT-5D93JGQ2  = Google Tag (Ads/linked products)
# Both fire unconditionally on every page.

# ── Google reCAPTCHA v3 ───────────────────────────────────────────────────────
# Get these from https://www.google.com/recaptcha/admin → v3 site
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6Lc...   # public — safe to expose
RECAPTCHA_SECRET_KEY=6Lc...             # secret — server only, never commit

# ── Meta / Facebook Pixel ─────────────────────────────────────────────────────
# CSO Inc. Pixel ID: 1533454933710050
# Found at: business.facebook.com → Events Manager → Data Sources → CSO Pixel
NEXT_PUBLIC_META_PIXEL_ID=1533454933710050

# Meta Conversions API access token for server-side purchase tracking
# Generate at: business.facebook.com → Events Manager → Settings > Conversions API > Generate access token
# Token must have "events" write permission
META_CAPI_ACCESS_TOKEN=your-capi-access-token

# ── Site URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://canadiansurrogacyoptions.com

# ── Staff Portal ──────────────────────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET=your-secret-here

# Neon Postgres (portal database)
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/cso_portal?sslmode=require
DIRECT_URL=postgresql://user:password@ep-xxx-direct.neon.tech/cso_portal?sslmode=require

# OpenAI (for AI-assisted PDF field extraction — optional but recommended)
OPENAI_API_KEY=sk-...
